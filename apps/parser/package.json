{
  "name": "@devtrends/parser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --test-scheduled --persist-to ../../.wrangler-state",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply devtrends --local --persist-to ../../.wrangler-state",
    "db:migrate:remote": "wrangler d1 migrations apply devtrends --remote",
    "db:query": "wrangler d1 execute devtrends --local --persist-to ../../.wrangler-state --command",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "linkedom": "^0.18.5",
    "openai": "^4.77.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.6.2",
    "wrangler": "^4.0.0"
  }
}
