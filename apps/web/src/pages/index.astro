---
import Base from "../layouts/Base.astro";
import ArticleCard from "../components/ArticleCard.astro";
import Sidebar from "../components/Sidebar.astro";
import SectionCard from "../components/SectionCard.astro";
import { getEnv, setCacheHeaders, siteUrl } from "../lib/site";
import { langColor, langLabel } from "../lib/lang";
import { listArticles, countArticles, listLanguages, publishedTagSets } from "../lib/db";
import { SECTIONS, tagsMatchSection } from "../lib/sections";
import { DEFAULT_LOCALE, localeHref, t } from "../lib/i18n";
import { websiteLd, organizationLd } from "../lib/seo";

const env = getEnv(Astro.locals);
const locale = Astro.locals.locale ?? DEFAULT_LOCALE;
setCacheHeaders(Astro, 300);

const q = (Astro.url.searchParams.get("q") ?? "").trim();
const perPage = 24;
const page = Math.max(1, Number(Astro.url.searchParams.get("page") ?? "1") || 1);
const offset = (page - 1) * perPage;

const [articles, total, languages] = await Promise.all([
  listArticles(env.DB, { limit: perPage, offset, q: q || undefined, locale }),
  countArticles(env.DB, undefined, q || undefined),
  listLanguages(env.DB),
]);
const totalAll = q ? await countArticles(env.DB) : total;
const totalPages = Math.max(1, Math.ceil(total / perPage));
const showHero = !q && page === 1;
const description = t(locale, "hero_blurb");

let sectionCards: { section: (typeof SECTIONS)[number]; count: number }[] = [];
if (showHero) {
  const tagSets = await publishedTagSets(env.DB);
  sectionCards = SECTIONS.map((section) => ({
    section,
    count: tagSets.filter((ts) => tagsMatchSection(ts, section)).length,
  })).filter((x) => x.count > 0);
}

const homeHref = localeHref(locale, "/");
const site = siteUrl(Astro.locals, Astro.url);
const jsonLd = [
  websiteLd(site, env.SITE_NAME),
  organizationLd(site, env.SITE_NAME, `${site}/icon-512.png`),
];
---

<Base
  title={q ? `${t(locale, "results_for")} ${q} | ${env.SITE_NAME}` : `${env.SITE_NAME} — ${t(locale, "hero_title")}`}
  description={description}
  path="/"
  ogType="website"
  jsonLd={jsonLd}
  noindex={!!q}
>
  {showHero && (
    <section class="mb-10 border-b border-line pb-10 dark:border-line-dark">
      <p class="eyebrow text-muted dark:text-muted-dark">{t(locale, "hero_eyebrow")}</p>
      <h1 class="mt-3 max-w-3xl font-display text-3xl font-bold leading-[1.08] tracking-tight sm:text-4xl xl:text-5xl">
        {t(locale, "hero_title")}
      </h1>
      <p class="mt-4 max-w-2xl text-muted dark:text-muted-dark">{t(locale, "hero_blurb")}</p>
      <p class="mt-4 font-mono text-sm text-muted dark:text-muted-dark">
        {totalAll.toLocaleString(locale)} {t(locale, "projects_word")} · {languages.length} {t(locale, "languages_word")} · {t(locale, "refreshed")}
      </p>
    </section>
  )}

  {showHero && sectionCards.length > 0 && (
    <section class="mb-12">
      <h2 class="eyebrow mb-4 text-muted dark:text-muted-dark">{t(locale, "browse_by_section")}</h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {sectionCards.map(({ section, count }) => <SectionCard section={section} count={count} />)}
      </div>
    </section>
  )}

  <div class="grid gap-8 lg:grid-cols-[14rem_minmax(0,1fr)]">
    <div class="hidden lg:block">
      <Sidebar languages={languages} />
    </div>

    <div>
      <!-- Mobile language chips (wrap to multiple rows; no horizontal scroll) -->
      <div class="mb-6 flex flex-wrap gap-2 lg:hidden">
        {languages.map((l) => (
          <a href={localeHref(locale, `/${l.language}`)} class="inline-flex items-center gap-1.5 rounded-full border border-line bg-surface px-3 py-1 text-xs font-medium dark:border-line-dark dark:bg-surface-dark">
            <span class="h-2 w-2 rounded-full" style={`background:${langColor(l.language)}`}></span>
            {langLabel(l.language)} <span class="font-mono text-muted dark:text-muted-dark">{l.n}</span>
          </a>
        ))}
      </div>

      <div class="mb-5 flex items-baseline justify-between gap-3">
        <h2 class="eyebrow text-muted dark:text-muted-dark">{q ? `${t(locale, "results_for")} “${q}”` : t(locale, "latest")}</h2>
        {q && (
          <a href={homeHref} class="font-mono text-xs text-muted underline-offset-2 hover:underline dark:text-muted-dark">{t(locale, "clear")} ✕</a>
        )}
      </div>

      {articles.length === 0 ? (
        <p class="rounded-xl border border-dashed border-line p-10 text-center text-muted dark:border-line-dark dark:text-muted-dark">
          {t(locale, "no_projects")}
        </p>
      ) : (
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {articles.map((a) => <ArticleCard article={a} />)}
        </div>
      )}

      {totalPages > 1 && (
        <nav class="mt-10 flex items-center justify-between" aria-label="Pagination">
          {page > 1 ? (
            <a href={page - 1 === 1 ? homeHref : `${homeHref}?page=${page - 1}`} rel="prev" class="rounded-lg border border-line px-4 py-2 font-mono text-sm hover:bg-line dark:border-line-dark dark:hover:bg-line-dark">← {t(locale, "newer")}</a>
          ) : <span></span>}
          <span class="font-mono text-xs text-muted dark:text-muted-dark">{page} / {totalPages}</span>
          {page < totalPages ? (
            <a href={`${homeHref}?page=${page + 1}`} rel="next" class="rounded-lg border border-line px-4 py-2 font-mono text-sm hover:bg-line dark:border-line-dark dark:hover:bg-line-dark">{t(locale, "older")} →</a>
          ) : <span></span>}
        </nav>
      )}
    </div>
  </div>
</Base>
