---
import Base from "../layouts/Base.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getEnv, canonical, setCacheHeaders } from "../lib/site";
import { listArticles, countArticles, listLanguages } from "../lib/db";

const env = getEnv(Astro.locals);
setCacheHeaders(Astro, 300);

const perPage = 24;
const page = Math.max(1, Number(Astro.url.searchParams.get("page") ?? "1") || 1);
const offset = (page - 1) * perPage;

const [articles, total, languages] = await Promise.all([
  listArticles(env.DB, { limit: perPage, offset }),
  countArticles(env.DB),
  listLanguages(env.DB),
]);

const totalPages = Math.max(1, Math.ceil(total / perPage));
const description = `Curated open-source developer tools and projects, translated to English. ${total} articles across ${languages.length} languages.`;
---

<Base
  title={env.SITE_NAME}
  description={description}
  canonicalUrl={canonical(env.SITE_URL, page > 1 ? `/?page=${page}` : "/")}
  siteName={env.SITE_NAME}
  ogType="website"
>
  <section class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{env.SITE_NAME}</h1>
    <p class="mt-3 max-w-2xl text-gray-600 dark:text-gray-300">{description}</p>
  </section>

  {languages.length > 0 && (
    <section id="languages" class="mb-10 scroll-mt-20">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">
        Browse by language
      </h2>
      <div class="flex flex-wrap gap-2">
        {languages.map((l) => (
          <a
            href={`/${l.language}`}
            class="rounded-full border border-gray-200 px-3 py-1 text-sm text-gray-700 hover:bg-gray-100 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800"
          >
            {l.language} <span class="text-gray-400">({l.n})</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section>
    <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">
      Latest
    </h2>
    {articles.length === 0 ? (
      <p class="text-gray-500 dark:text-gray-400">No articles published yet.</p>
    ) : (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {articles.map((a) => <ArticleCard article={a} />)}
      </div>
    )}
  </section>

  {totalPages > 1 && (
    <nav class="mt-10 flex items-center justify-between" aria-label="Pagination">
      {page > 1 ? (
        <a href={page - 1 === 1 ? "/" : `/?page=${page - 1}`} rel="prev" class="rounded-md border border-gray-300 px-4 py-2 text-sm dark:border-gray-700">
          &larr; Newer
        </a>
      ) : <span></span>}
      <span class="text-sm text-gray-500 dark:text-gray-400">Page {page} of {totalPages}</span>
      {page < totalPages ? (
        <a href={`/?page=${page + 1}`} rel="next" class="rounded-md border border-gray-300 px-4 py-2 text-sm dark:border-gray-700">
          Older &rarr;
        </a>
      ) : <span></span>}
    </nav>
  )}
</Base>
