---
import Base from "../../layouts/Base.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import Sidebar from "../../components/Sidebar.astro";
import { getEnv, setCacheHeaders } from "../../lib/site";
import { langColor, langLabel } from "../../lib/lang";
import { listArticles, countArticles, listLanguages } from "../../lib/db";
import { DEFAULT_LOCALE, localeHref, t } from "../../lib/i18n";

const { lang } = Astro.params as { lang: string };
const env = getEnv(Astro.locals);
const locale = Astro.locals.locale ?? DEFAULT_LOCALE;

const [total, languages] = await Promise.all([
  countArticles(env.DB, lang),
  listLanguages(env.DB),
]);
if (total === 0) {
  return new Response("Not Found", { status: 404 });
}
setCacheHeaders(Astro, 300);

const perPage = 24;
const page = Math.max(1, Number(Astro.url.searchParams.get("page") ?? "1") || 1);
const offset = (page - 1) * perPage;
const articles = await listArticles(env.DB, { limit: perPage, offset, language: lang, locale });
const totalPages = Math.max(1, Math.ceil(total / perPage));

const label = langLabel(lang);
const color = langColor(lang);
const basePath = localeHref(locale, `/${lang}`);
const description = `${label} — ${total} ${t(locale, "projects_word")}.`;
---

<Base title={`${label} | ${env.SITE_NAME}`} description={description} path={`/${lang}`} ogType="website">
  <div class="grid gap-8 lg:grid-cols-[14rem_minmax(0,1fr)]">
    <div class="hidden lg:block">
      <Sidebar languages={languages} active={lang} />
    </div>

    <div>
      <nav class="mb-4 font-mono text-xs text-muted dark:text-muted-dark" aria-label="Breadcrumb">
        <a href={localeHref(locale, "/")} class="hover:underline">~</a> <span class="mx-1">/</span> <span>{lang}</span>
      </nav>

      <header class="mb-8 flex flex-wrap items-center gap-x-3 gap-y-2 border-b border-line pb-6 dark:border-line-dark">
        <span class="h-5 w-5 rounded-full" style={`background:${color}`} aria-hidden="true"></span>
        <h1 class="font-display text-3xl font-bold tracking-tight">{label}</h1>
        <span class="font-mono text-sm text-muted dark:text-muted-dark">{total} {t(locale, "projects_word")}</span>
      </header>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {articles.map((a) => <ArticleCard article={a} />)}
      </div>

      {totalPages > 1 && (
        <nav class="mt-10 flex items-center justify-between" aria-label="Pagination">
          {page > 1 ? (
            <a href={page - 1 === 1 ? basePath : `${basePath}?page=${page - 1}`} rel="prev" class="rounded-lg border border-line px-4 py-2 font-mono text-sm hover:bg-line dark:border-line-dark dark:hover:bg-line-dark">← {t(locale, "newer")}</a>
          ) : <span></span>}
          <span class="font-mono text-xs text-muted dark:text-muted-dark">{page} / {totalPages}</span>
          {page < totalPages ? (
            <a href={`${basePath}?page=${page + 1}`} rel="next" class="rounded-lg border border-line px-4 py-2 font-mono text-sm hover:bg-line dark:border-line-dark dark:hover:bg-line-dark">{t(locale, "older")} →</a>
          ) : <span></span>}
        </nav>
      )}
    </div>
  </div>
</Base>
