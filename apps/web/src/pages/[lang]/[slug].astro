---
import Base from "../../layouts/Base.astro";
import { getEnv, canonical, articlePath, formatDate, setCacheHeaders } from "../../lib/site";
import { getArticle, parseTags } from "../../lib/db";

const { lang, slug } = Astro.params as { lang: string; slug: string };
const env = getEnv(Astro.locals);

const article = await getArticle(env.DB, lang, slug);
if (!article) {
  return new Response("Not Found", { status: 404 });
}
setCacheHeaders(Astro, 600);

const url = canonical(env.SITE_URL, articlePath(article.language, article.slug));
const tags = parseTags(article.tags);
const date = formatDate(article.source_lastmod ?? article.updated_at);
const description = article.meta_description ?? article.excerpt_en ?? "";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: article.title_en,
  description,
  inLanguage: "en",
  mainEntityOfPage: { "@type": "WebPage", "@id": url },
  ...(article.og_image ? { image: article.og_image } : {}),
  ...(article.source_date ? { datePublished: article.source_date } : {}),
  ...(article.updated_at ? { dateModified: article.updated_at } : {}),
  ...(tags.length ? { keywords: tags.join(", ") } : {}),
};
---

<Base
  title={`${article.title_en} | ${env.SITE_NAME}`}
  description={description}
  canonicalUrl={url}
  ogImage={article.og_image}
  ogType="article"
  siteName={env.SITE_NAME}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-3xl">
    <nav class="mb-4 text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <a href="/" class="hover:underline">Home</a>
      <span class="mx-1">/</span>
      <a href={`/${article.language}`} class="hover:underline">{article.language}</a>
    </nav>

    <header class="mb-6 border-b border-gray-200 pb-6 dark:border-gray-800">
      <h1 class="text-3xl font-bold leading-tight tracking-tight sm:text-4xl">{article.title_en}</h1>
      <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-gray-500 dark:text-gray-400">
        <a href={`/${article.language}`} class="rounded-full bg-gray-100 px-2 py-0.5 font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-200">{article.language}</a>
        {article.github_stars != null && <span>★ {article.github_stars.toLocaleString("en-US")}</span>}
        {date && <time>{date}</time>}
      </div>
    </header>

    <div class="prose prose-gray max-w-none dark:prose-invert" set:html={article.body_html_en} />

    {tags.length > 0 && (
      <footer class="mt-10 border-t border-gray-200 pt-6 dark:border-gray-800">
        <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Tags</h2>
        <div class="flex flex-wrap gap-2">
          {tags.map((t) => (
            <span class="rounded-full bg-gray-100 px-3 py-1 text-sm text-gray-700 dark:bg-gray-800 dark:text-gray-200">#{t}</span>
          ))}
        </div>
      </footer>
    )}

    <p class="mt-8 text-xs text-gray-400 dark:text-gray-500">
      Translated from the original Russian article.
      <a href={article.source_url} rel="nofollow noopener" class="underline hover:text-gray-600 dark:hover:text-gray-300" target="_blank">View source</a>.
    </p>
  </article>
</Base>
