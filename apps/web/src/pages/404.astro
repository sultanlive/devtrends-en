---
import Base from "../layouts/Base.astro";
import { getEnv, canonical } from "../lib/site";
const env = getEnv(Astro.locals);
---

<Base
  title={`Not found | ${env.SITE_NAME}`}
  description="Page not found"
  canonicalUrl={canonical(env.SITE_URL, "/404")}
  siteName={env.SITE_NAME}
>
  <section class="py-24 text-center">
    <p class="eyebrow text-muted dark:text-muted-dark">Error</p>
    <h1 class="mt-2 font-display text-6xl font-bold tracking-tight">404</h1>
    <p class="mt-4 text-muted dark:text-muted-dark">We couldn't find that page.</p>
    <a href="/" class="mt-6 inline-block rounded-lg border border-line px-4 py-2 font-mono text-sm hover:bg-line dark:border-line-dark dark:hover:bg-line-dark">← Back home</a>
  </section>
</Base>
