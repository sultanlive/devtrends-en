---
import Base from "../layouts/Base.astro";
import { DEFAULT_LOCALE, localeHref, t } from "../lib/i18n";
const locale = Astro.locals.locale ?? DEFAULT_LOCALE;
---

<Base title="404" description={t(locale, "not_found_sub")} path="/404" noindex={true}>
  <section class="py-24 text-center">
    <p class="eyebrow text-muted dark:text-muted-dark">{t(locale, "error")}</p>
    <h1 class="mt-2 font-display text-6xl font-bold tracking-tight">404</h1>
    <p class="mt-4 text-muted dark:text-muted-dark">{t(locale, "not_found_sub")}</p>
    <a href={localeHref(locale, "/")} class="mt-6 inline-block rounded-lg border border-line px-4 py-2 font-mono text-sm hover:bg-line dark:border-line-dark dark:hover:bg-line-dark">← {t(locale, "back_home")}</a>
  </section>
</Base>
