---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getEnv, canonical, siteUrl } from "../lib/site";
import { LOCALES, DEFAULT_LOCALE, localeHref } from "../lib/i18n";

export interface Props {
  title: string;
  description?: string;
  /** Locale-agnostic root-relative path (e.g. "/go/rclone-rclone"). */
  path?: string;
  ogImage?: string | null;
  ogType?: "website" | "article";
  jsonLd?: Record<string, unknown> | Record<string, unknown>[] | null;
  noindex?: boolean;
}

const { title, description = "", path = "/", ogImage = null, ogType = "website", jsonLd = null, noindex = false } = Astro.props;

const env = getEnv(Astro.locals);
const locale = Astro.locals.locale ?? DEFAULT_LOCALE;
const siteName = env.SITE_NAME;
const site = siteUrl(Astro.locals, Astro.url);
const twitterHandle = env.TWITTER_HANDLE;
// Load Google Analytics only in production builds and only when configured, so
// dev/preview traffic doesn't pollute the stats.
const gaId = import.meta.env.PROD ? env.GA_ID : "";
const ldItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

const canonicalUrl = canonical(site, localeHref(locale, path));
const alternates = LOCALES.map((loc) => ({
  loc,
  href: canonical(site, localeHref(loc, path)),
}));
---

<!doctype html>
<html lang={locale} class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}

    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicons / app icons -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f4f5f7" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0b0e14" />

    {/* hreflang alternates for every locale + x-default */}
    {alternates.map((a) => <link rel="alternate" hreflang={a.loc} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={canonical(site, localeHref(DEFAULT_LOCALE, path))} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={locale} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {twitterHandle && <meta name="twitter:site" content={twitterHandle} />}

    {ldItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}

    <!-- Fonts: Space Grotesk (display) + IBM Plex Sans/Mono. Loaded
         non-render-blocking (display=swap shows fallback text immediately). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      />
    </noscript>

    <!-- Pre-paint theme init (no FOUC); no framework needed. -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("theme");
          const dark = stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.classList.toggle("dark", dark);
        } catch (_) {}
        window.toggleTheme = function () {
          const el = document.documentElement;
          const isDark = el.classList.toggle("dark");
          try { localStorage.setItem("theme", isDark ? "dark" : "light"); } catch (_) {}
        };
      })();
    </script>
  </head>
  <body class="flex min-h-full flex-col bg-paper text-ink antialiased dark:bg-paper-dark dark:text-ink-dark">
    <Header siteName={siteName} />
    <main class="mx-auto w-full max-w-[1600px] flex-1 px-4 py-8 sm:px-6 lg:px-8">
      <slot />
    </main>
    <Footer siteName={siteName} />

    <!-- Alpine: powers only the mobile menu (Zero-JS elsewhere). -->
    <script>
      import Alpine from "alpinejs";
      window.Alpine = Alpine;
      Alpine.start();
    </script>
  </body>
</html>
